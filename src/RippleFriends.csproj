<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>
  
  <ItemGroup>
    <Reference Include="..\lib\BepInEx.dll"/>
    <Reference Include="..\lib\HOOKS-Assembly-CSharp.dll"/>
    <Reference Include="..\lib\Mono.Cecil.dll"/>
    <Reference Include="..\lib\MonoMod.Utils.dll"/>
    <Reference Include="..\lib\PUBLIC-Assembly-CSharp.dll"/>
    <Reference Include="..\lib\UnityEngine.dll"/>
    <Reference Include="..\lib\UnityEngine.CoreModule.dll"/>
  </ItemGroup>
  
  <PropertyGroup>
    <ModOutputPath>..\release\</ModOutputPath>
  </PropertyGroup>

  <Target Name="DeployMod" AfterTargets="Build">
    <ItemGroup>
      <PluginFiles Include="$(TargetPath)" />
      <AssetFiles Include="..\assets\**\*" />
    </ItemGroup>

    <Copy SourceFiles="@(PluginFiles)" DestinationFolder="$(ModOutputPath)plugins" SkipUnchangedFiles="true" />    
    <Copy SourceFiles="@(AssetFiles)" DestinationFiles="$(ModOutputPath)%(RecursiveDir)%(Filename)%(Extension)" SkipUnchangedFiles="true" />
  </Target>

</Project>
